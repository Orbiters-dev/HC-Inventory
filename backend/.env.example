# HC-Inventory 계산기 백엔드 환경변수 (실제 .env 는 git 미추적 — public repo 라 시크릿 금지)

# Django
HC_SECRET_KEY=                 # python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
HC_DEBUG=0
HC_ALLOWED_HOSTS=hc.example.com,localhost,127.0.0.1
HC_CSRF_TRUSTED_ORIGINS=https://hc.example.com
HC_SECURE=1                    # 1=HTTPS 강제(SSL redirect/HSTS/secure cookie). 로컬 0
HC_SESSION_AGE=28800           # 세션 만료(초), 기본 8h

# DB — 전용 PostgreSQL (EC2 5434, WONGI 5433 과 분리). 로컬/CI 는 HC_DB_ENGINE=sqlite
HC_DB_ENGINE=postgresql        # 또는 sqlite (로컬/CI)
HC_DB_NAME=hc_inventory
HC_DB_USER=hc_user
HC_DB_PASSWORD=
HC_DB_HOST=127.0.0.1
HC_DB_PORT=5434
